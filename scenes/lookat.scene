# lookat.scene - demonstrates the optional camera look-at form (px py pz fov lx ly lz)
# The camera sits up and off to the side and is aimed back at the origin, so the
# scene is viewed from an angle instead of straight down +z.
camera 6 5 -7 0.5 0 0 0
sky 0.40 0.60 0.95  0.85 0.90 1.0
light -8 10 -6 1 1 1 1.3
plane 0 1 0 1.5  0.85 0.85 0.85  0.30 0.30 0.30
sphere 0 0 0 1.5  0.90 0.25 0.20 reflect 0.35 80
sphere 3 -0.5 1 1  0.20 0.45 0.90
box -3 -1.5 -1  -1 1.0 1  0.25 0.80 0.35
