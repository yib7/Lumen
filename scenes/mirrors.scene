# mirrors.scene - reflective spheres and boxes on a dark glossy floor.
# Shows off recursive reflections: the chrome sphere mirrors its neighbors,
# which in turn mirror it, so raising --depth visibly changes the result.

camera  0 0.6 0  0.5

sky  0.08 0.09 0.14   0.20 0.22 0.30

light   -6  8 -2   1.0 0.95 0.9   1.6
light    7  5 -1   0.6 0.7  1.0   0.6

# Dark, strongly reflective floor.
plane  0 1 0  1.2   0.04 0.04 0.05   0.10 0.10 0.12   reflect 0.5 120

# A near-chrome sphere in the middle.
sphere  0.0 1.4 5.0  1.0   0.85 0.85 0.90   reflect 0.85 250

# Two colored matte spheres flanking it.
sphere -1.9 0.7 4.2  0.55   0.90 0.25 0.20
sphere  1.9 0.7 4.2  0.55   0.20 0.55 0.95

# A reflective box and a matte box behind.
box  -1.3 -1.2 5.6   -0.2 0.4 6.4    0.95 0.75 0.15   reflect 0.4 90
box   0.4 -1.2 6.0    1.4 0.7 6.9    0.30 0.85 0.45
